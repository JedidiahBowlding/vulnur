t# ===============================
# Smart Contract Monitor Settings
# ===============================

# Required RPC endpoint from Infura OR Alchemy.
# Pick one of the examples and replace with your real key.
# Infura example:
# RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_API_KEY
# Alchemy example:
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
RPC_URL=

# Optional: keep your provider keys here for reference.
INFURA_API_KEY=
ALCHEMY_API_KEY=

# Optional per-chain RPC URLs used by protocol scan adapters.
RPC_URL_BNB_CHAIN=
RPC_URL_POLYGON=
RPC_URL_ARBITRUM=
RPC_URL_BASE=
RPC_URL_OPTIMISM=
RPC_URL_AVALANCHE=

# Solana adapter (defaults to public mainnet RPC; use a private endpoint for reliability)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional SolScan API token for richer program metadata
SOLSCAN_TOKEN=
# Optional: path/command for cargo-audit (Rust advisory scanner)
CARGO_AUDIT_CMD=cargo-audit

# Polling behavior
POLLING_INTERVAL_SECONDS=30
# Optional: if blank, the scanner starts from latest block - 1 on first run.
START_BLOCK=

# Tool commands (must be installed and available in PATH)
SLITHER_CMD=slither
MYTHRIL_CMD=myth
ECHIDNA_CMD=echidna

# Optional source lookup for Slither/Echidna against verified contracts
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/api

# DeFi protocol scan safety guard (max contracts per batch API call)
PROTOCOL_SCAN_MAX_CONTRACTS=50

# Optional CoinMarketCap integration for discovering DeFi protocols/contracts.
# Keyless endpoint may return 402 if wallet-based payment is required.
CMC_API_KEY=
CMC_KEYLESS_DEX_SEARCH_URL=https://api.coinmarketcap.com/x402/v1/dex/search
CMC_TIMEOUT_SECONDS=20

# Telegram bot credentials (required for Telegram alerts)
# 1) Create bot with @BotFather and copy token
# 2) Get chat id for your user/group/channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional generic webhook for scan events (POST JSON)
ALERT_WEBHOOK_URL=

# Local persistence
SQLITE_PATH=./data/monitor.db
